cat > .env.example <<'EOF'
# Petrodactal Game Monitor (example config)
# Copy to .env and fill in the real values. Do NOT commit .env to GitHub.

DEBUG=0

# Comma-separated list
ALLOWED_HOSTS=monitor.cymru-hosting.co.uk,localhost,127.0.0.1

# For HTTPS deployments, set this:
CSRF_TRUSTED_ORIGINS=https://monitor.cymru-hosting.co.uk

# Django secret key (installer can generate this)
SECRET_KEY=

# Encryption key for storing API keys encrypted in DB (installer can generate this)
ENCRYPTION_KEY=

# Pterodactyl connection
PTERO_BASE_URL=https://panel.your-domain.tld
PTERO_APPLICATION_API_KEY=
PTERO_CLIENT_API_KEY=

# Optional notifications
DISCORD_WEBHOOK_URL=
EOF
